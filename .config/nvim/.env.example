# Copy this file to .env.local or .env and keep the copy untracked.
# Scoped Avante keys are preferred so they do not leak into unrelated tooling.

AVANTE_ANTHROPIC_API_KEY=
AVANTE_OPENAI_API_KEY=
AVANTE_GEMINI_API_KEY=
AVANTE_GROQ_API_KEY=

# Optional global fallbacks for tools that do not support scoped env vars.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
